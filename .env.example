# Environment Configuration Template
# Copy this to .env and fill in your values

# ===== DATABASE =====
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=service_finder
DB_PORT=3306

# ===== SITE CONFIGURATION =====
SITE_NAME=Service Finder Pakistan
SITE_URL=http://localhost/mids/
TIMEZONE=Asia/Karachi
CURRENCY=PKR

# ===== SECURITY =====
JWT_SECRET=change-this-to-a-random-32-character-string-minimum
CSRF_TOKEN_EXPIRY=3600

# Password Requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# ===== PAGINATION =====
ITEMS_PER_PAGE=12
SEARCH_RESULTS_PER_PAGE=20

# ===== FILE UPLOAD =====
MAX_FILE_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf
UPLOAD_DIR=uploads/

# ===== PAYMENT GATEWAYS =====

# Stripe (International Card Payments)
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# JazzCash (Pakistani Mobile Money)
JAZZCASH_MERCHANT_ID=...
JAZZCASH_PASSWORD=...
JAZZCASH_SECURE_KEY=...
JAZZCASH_API_KEY=...
JAZZCASH_API_URL=https://sandbox.jazzcash.com.pk

# ===== COMMUNICATION SERVICES =====

# Email via SendGrid
SENDGRID_API_KEY=SG.xxxxx...
SENDER_EMAIL=noreply@servicefinder.pk
SENDER_NAME=Service Finder Pakistan

# SMS via Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1234567890

# ===== AI & ML SERVICES =====

# OpenAI API
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Vector Database - Pinecone
PINECONE_API_KEY=...
PINECONE_ENVIRONMENT=gcp-starter
PINECONE_INDEX_NAME=services

# ===== LOCATION SERVICES =====

# Google Maps API
GOOGLE_MAPS_API_KEY=AIzaSyD...
GOOGLE_MAPS_SERVER_KEY=...

# ===== CACHE & STORAGE =====

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# Session
SESSION_DRIVER=file
SESSION_LIFETIME=3600

# ===== EXTERNAL INTEGRATIONS =====

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret-key-here
WEBHOOK_TIMEOUT=30
WEBHOOK_MAX_RETRIES=5

# Business Logic
SERVICE_COMMISSION=10
MIN_RATING=1
MAX_RATING=5

# ===== BOOKING STATUS =====
BOOKING_STATUS_PENDING=pending
BOOKING_STATUS_CONFIRMED=confirmed
BOOKING_STATUS_IN_PROGRESS=in_progress
BOOKING_STATUS_COMPLETED=completed
BOOKING_STATUS_CANCELLED=cancelled

# ===== PAYMENT STATUS =====
PAYMENT_STATUS_PENDING=pending
PAYMENT_STATUS_COMPLETED=completed
PAYMENT_STATUS_FAILED=failed
PAYMENT_STATUS_REFUNDED=refunded

# ===== USER TYPES =====
USER_TYPE_CUSTOMER=customer
USER_TYPE_SERVICE_PROVIDER=service_provider
USER_TYPE_ADMIN=admin
USER_TYPE_SUPPORT=support

# ===== API CONFIGURATION =====

# API Rate Limiting
API_RATE_LIMIT_GENERAL=100
API_RATE_LIMIT_WINDOW=3600
API_RATE_LIMIT_SEARCH=300
API_RATE_LIMIT_LOGIN=10

# Allowed CORS Origins
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8000

# ===== LOGGING & MONITORING =====

# Logging
LOG_LEVEL=info
LOG_CHANNEL=single
LOG_PATH=storage/logs/

# Error Reporting (optional)
SENTRY_DSN=

# Analytics
GOOGLE_ANALYTICS_ID=

# ===== DEVELOPMENT =====

# Environment
APP_ENV=development
APP_DEBUG=true

# If you have API testing tools
POSTMAN_API_KEY=

# ===== NOTIFICATIONS =====

# Push Notifications (Firebase)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ===== EXTERNAL APIs =====

# Weather Service (Optional)
WEATHER_API_KEY=

# Currency Exchange (Optional)
EXCHANGE_RATE_API_KEY=

# ===== BACKUP & MAINTENANCE =====

# Database Backup
BACKUP_PATH=backups/
BACKUP_RETENTION_DAYS=30

# ===== IMPORTANT NOTES =====
#
# 1. NEVER commit this file to git
# 2. Keep .env in .gitignore
# 3. Use strong random values for secret keys
# 4. Rotate keys/tokens regularly
# 5. Different .env for dev, staging, production
# 6. Encrypt sensitive values in production
#
# Generate random strings:
# Linux/Mac: openssl rand -hex 32
# PHP: bin2hex(random_bytes(16))
#
